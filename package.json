{
  "name": "@open-ai-school/ai-ui-library",
  "version": "0.1.1",
  "description": "Shared UI component library for Open AI School — React, TypeScript, Tailwind CSS, Framer Motion",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/open-ai-school/ai-ui-library"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "tailwindcss",
    "education",
    "open-ai-school",
    "design-system"
  ],
  "author": "Ramesh Reddy Adutla <rameshreddy.adutla@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/open-ai-school/ai-ui-library/issues"
  },
  "homepage": "https://github.com/open-ai-school/ai-ui-library#readme",
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-themes": "^8.6.14",
    "@storybook/react": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.39.3",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "^8.6.14",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "framer-motion": "^12.15.0",
    "lucide-react": "^0.525.0",
    "next-themes": "^0.4.6"
  }
}
